int main(){
decl
    int temp,pid,a;
    string s;
    string prompt;
enddecl
begin
    s = "";
    a = 1;
    prompt = "fname:)";
    while(a == 1) do
        temp = exposcall("Write",-2,prompt);
        temp = exposcall("Read",-1,s);
        pid = exposcall("Fork");
        if(s == "Shutdown") then
            break;
        endif;
        if(pid < 0) then
            temp = exposcall("Write",-2, "Fork Failure");
            continue;
        endif;
        if(pid == 0) then
            temp = exposcall("Exec",s);
            if(temp != 0) then
                temp = exposcall("Write",-2, "BAD COMMAND");
            endif;
        else
            temp = exposcall("Wait",pid);
        endif;
    endwhile;
    temp = exposcall("Shutdown");
    return 0;
end
}