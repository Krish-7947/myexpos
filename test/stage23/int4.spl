alias userSP R0;
userSP = SP;

alias currPID R7;
alias procTab R8;
alias rAdd R9;

currPID = [SYSTEM_STATUS_TABLE + 1];
procTab = PROCESS_TABLE + currPID*16;
rAdd = [PTBR + 2 * ((userSP - 1)/512)]*512 + (userSP - 1) % 512;

[procTab + 13] = SP;
SP = [procTab + 11] * 512 - 1;

alias sysCallNo R1;
sysCallNo = [[PTBR + 2 * ((userSP - 5)/512)]*512 + (userSP - 5) % 512];

[procTab + 9] = sysCallNo;
if(sysCallNo == 1) then

    alias filename R2;
    filename = [[PTBR + 2 * ((userSP - 4)/512)]*512 + (userSP - 4) % 512];
    alias permission R3;
    permission = [[PTBR + 2 * ((userSP - 3)/512)]*512 + (userSP - 3) % 512];

    alias i R4;
    i = 1;
    while(i < MAX_FILE_NUM) do
        if([INODE_TABLE + i*16 + 1] == filename) then
            [rAdd] = 0;
            [procTab + 9] = 0;
            SP = userSP;
            ireturn;
        endif;
        i = i + 1;
    endwhile;

    i = 1;
    while(i < MAX_FILE_NUM) do
        if([INODE_TABLE + i*16 + 1] == -1) then
            break;
        endif;
        i = i + 1;
    endwhile;
    if(i == MAX_FILE_NUM) then
        [rAdd] = -1;
        [procTab + 9] = 0;
        SP = userSP;
        ireturn;
    endif;

    alias inodeEntry R10;
    inodeEntry = INODE_TABLE + i*16;
    [inodeEntry] = DATA;
    [inodeEntry + 1] = filename;
    [inodeEntry + 2] = 0;

    [inodeEntry + 8] = -1;
    [inodeEntry + 9] = -1;
    [inodeEntry + 10] = -1;
    [inodeEntry + 11] = -1;

    [inodeEntry + 3] = [PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1]*16 + 3];
    [inodeEntry + 4] = permission;

    alias rootEntry R10;
    rootEntry = ROOT_FILE + i*16;
    [rootEntry] = filename;
    [rootEntry + 1] = 0;
    [rootEntry + 2] = DATA;
    [rootEntry + 3] = [USER_TABLE + 2*[procTab + 3]];
    [rootEntry + 4] = permission;
endif;
if(sysCallNo == 4) then
    alias filename R2;
    filename = [[PTBR + 2 * ((userSP - 4)/512)]*512 + (userSP - 4) % 512];

    alias i R3;
    i = 1;
    while(i < MAX_FILE_NUM) do
        if([INODE_TABLE + i*16 + 1] == filename) then
            break;
        endif;
        i = i + 1;
    endwhile;
    if(i == MAX_FILE_NUM) then
        [procTab + 9] = 0;
        [rAdd] = 0;
        SP = userSP;
        ireturn;
    endif;
    if([INODE_TABLE + i*16] != DATA) then
        [procTab + 9] = 0;
        [rAdd] = -1;
        SP = userSP;
        ireturn;
    endif;
    
    alias inodeEntry R10;
    inodeEntry = INODE_TABLE + i*16;
    if([inodeEntry + 4] == EXCLUSIVE) then
		if([inodeEntry + 3] != [SYSTEM_STATUS_TABLE] && [SYSTEM_STATUS_TABLE] != 1) then
			[procTab + 9] = 0;
            [rAdd] = -1;
            SP = userSP;
            ireturn;
		endif;
	endif;

    multipush(R0, R1, R2, R3, R7, R8 ,R9, R10);
	R1 = 4;
	R3 = currPID;
	R2 = i;
	call MOD_0;
	multipop(R0, R1, R2, R3, R7, R8 ,R9, R10);

    if([FILE_STATUS_TABLE + 4*i + 1] != -1) then
        multipush(R0, R1, R2, R3, R7, R8 ,R9, R10);
	    R1 = 5;
	    R3 = currPID;
	    R2 = i;
	    call MOD_0;
	    multipop(R0, R1, R2, R3, R7, R8 ,R9, R10);

        [procTab + 9] = 0;
        [rAdd] = -2;
        SP = userSP;
        ireturn;
    endif;

    alias j R4;
    j = 8;
    while(j < 12) do
        if([inodeEntry + j] != -1) then
            alias blocknum R5;
            blocknum = [inodeEntry + j];
            alias bufferEntry R6;
            bufferEntry = BUFFER_TABLE + (blocknum%MAX_BUFFER)*4;

            if([bufferEntry] == blocknum && [bufferEntry + 1] == 1) then
                [bufferEntry + 1] = 0;
            endif;

            multipush(R0, R1, R2, R3, R7, R8 ,R9, R10);
	    	R1 = 4;
	    	R3 = currPID;
	    	R2 = blocknum;
	    	call MOD_2;
	    	multipop(R0, R1, R2, R3, R7, R8 ,R9, R10);

        endif;
        j = j + 1;
    endwhile;

    j = 0;
	while(j<16) do
		if(j<5) then
			[ROOT_FILE + i*8 + j] = -1;
		endif;
		[inodeEntry + j] = -1;
		j = j + 1;
	endwhile;

    multipush(R0, R1, R2, R3, R7, R8 ,R9, R10);
	R1 = 5;
	R2 = currPID;
	call MOD_0;
	multipop(R0, R1, R2, R3, R7, R8 ,R9, R10);
endif;

[PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1]*16 + 9] = 0;
[[PTBR + 2 * ((userSP - 1)/512)]*512 + (userSP - 1) % 512] = 0;
SP = userSP;
ireturn;