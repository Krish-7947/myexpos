alias functionNum R1;
alias currentPID R2;
alias word R3;

if(functionNum == 2) then
    alias memorypage R3;
    alias diskpage R4;

    multipush(R1,R2,R3,R4);

    R1 = 3;
    R2 = currentPID;
    call MOD_0;

    multipop(R1,R2,R3,R4);

    [DISK_STATUS_TABLE + 1] = 0;
    [DISK_STATUS_TABLE + 2] = memorypage;
    [DISK_STATUS_TABLE + 3] = diskpage;

    load(memorypage,diskpage);

    [PROCESS_TABLE + currentPID*16 + 4] = WAIT_DISK;

    multipush(R1,R2,R3,R4);
    call MOD_5;
    multipop(R1,R2,R3,R4);

    return;
endif;
if (functionNum == 3) then
    multipush(R1, R2, R3);
    functionNum = 8;

    call MOD_0;

    multipop(R1, R2, R3);

    print word;

    multipush(R1, R2, R3);

    functionNum = 9;

    call MOD_0;

    multipop(R1, R2, R3);

    return;
endif;
if (functionNum == 4) then
    multipush(R1, R2, R3);
    functionNum = 8;

    call MOD_0;

    multipop(R1, R2, R3);

    read;

    [PROCESS_TABLE + currentPID * 16 + 4] = WAIT_TERMINAL;

    multipush(R1, R2, R3);

    call MOD_5;

    multipop(R1, R2, R3);

    [[PTBR + 2 * (word / 512)] * 512 + (word % 512)] = [PROCESS_TABLE + currentPID * 16 + 8];
    
    return;
endif;