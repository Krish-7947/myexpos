type
    node {
        int val;
        node next;
    }
endtype

decl
    node head,temp,inputnode;
enddecl

int main(){
decl
    int n,x,t,i;
enddecl
begin
    t = exposcall("Write",-2,"Enter n: ");
    t = exposcall("Read",-1,n);
    t = initialize();
    head = alloc();
    temp = head;

    i=0;
    while(i<n) do
        t = exposcall("Read",-1,x);
        inputnode = alloc();
        inputnode.val = x;
        temp.next = inputnode;
        temp = temp.next;
        i = i + 1;
    endwhile;

    i=0;
    temp = head.next;
    t = exposcall("Write",-2,"List: ");

    while(i<n) do
        t = exposcall("Write",-2,temp.val);
        temp = temp.next;
        i = i + 1;
    endwhile;
    return 0;
end
}